generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMY (Typy wyliczeniowe)
// ==========================================

enum AbsenceType {
  HOLIDAY
  SICK_LEAVE
  UNEXCUSED
  SPECIAL
}

enum AnomalyStatus {
  OPEN
  RESOLVED
}

enum CertificationType {
  BHP
  MEDICAL
  UDT
  OTHER
}

enum ContractType {
  UOP
  UZ
  UD
  B2B
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  COMPLETED
  SUSPENDED
}

enum TimeEventAction {
  IN
  OUT
}

enum UserRole {
  ADMIN
  HR
  OFFICE
  FOREMAN
  ACCOUNTING
  WORKER
}

// ==========================================
// MODELE (Tabele)
// ==========================================

/// Centralna tabela osob (Pracownik + Użytkownik)
model Employee {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName          String
  lastName           String
  pesel              String?   @unique @db.VarChar(11)
  rfidCardId         String?   @unique
  email              String?   @unique
  passwordHash       String?
  role               UserRole  @default(WORKER)
  isActive           Boolean   @default(true)
  isLoginEnabled     Boolean   @default(false)
  isTwoFactorEnabled Boolean   @default(false)
  twoFactorSecret    String?
  createdAt          DateTime? @default(now()) @db.Timestamptz
  updatedAt          DateTime? @db.Timestamptz

  // Relacje zwrotne
  absences         Absence[]
  anomalies        Anomaly[]
  contracts        Contract[]
  documents        Document[]
  assignments      EmployeeAssignment[]
  certifications   EmployeeCertification[]
  generatedExports PayrollExport[]         @relation("ExportGenerator")
  timeEntries      TimeEntry[]
  timeEvents       TimeEvent[]
}

/// Słownik/Katalog wszystkich możliwych szkoleń i uprawnień w firmie.
model CertificationDictionary {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type                  CertificationType
  name                  String            @unique
  description           String?
  defaultValidityMonths Int?
  isActive              Boolean?          @default(true)
  createdAt             DateTime?         @default(now()) @db.Timestamptz

  // Relacje zwrotne
  employeeCertifications EmployeeCertification[]
}

/// Błędy do ręcznej korekty przez biuro/brygadzistę
model Anomaly {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId  String        @db.Uuid
  timeEventId String?       @db.Uuid
  description String
  status      AnomalyStatus @default(OPEN)
  resolvedAt  DateTime?     @db.Timestamptz
  createdAt   DateTime?     @default(now()) @db.Timestamptz

  // Relacje
  employee  Employee   @relation(fields: [employeeId], references: [id])
  timeEvent TimeEvent? @relation(fields: [timeEventId], references: [id])

  // Indeksy optymalizacyjne
  @@index([employeeId])
  @@index([timeEventId])
}

/// Relacja wiele-do-wielu z historią (Kto, Gdzie, Kiedy)
model EmployeeAssignment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String    @db.Uuid
  projectId    String    @db.Uuid
  assignedAt   DateTime  @default(now()) @db.Timestamptz
  unassignedAt DateTime? @db.Timestamptz
  notes        String?
  createdAt    DateTime? @default(now()) @db.Timestamptz

  // Relacje
  employee Employee @relation(fields: [employeeId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id])

  @@index([employeeId])
  @@index([projectId])
}

/// Rejestr urlopow i L4. Blokuje możliwość odbicia karty na czytniku, jeśli isApproved = true.
model Absence {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String      @db.Uuid
  type       AbsenceType
  startDate  DateTime    @db.Date
  endDate    DateTime    @db.Date
  documentId String?     @db.Uuid
  isApproved Boolean?    @default(false)
  createdAt  DateTime?   @default(now()) @db.Timestamptz

  // Relacje
  document Document? @relation(fields: [documentId], references: [id])
  employee Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

/// Przetworzone dniowki (wygenerowane przez system na podstawie TimeEvent)
model TimeEntry {
  payrollExportId String?   @db.Uuid
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId      String    @db.Uuid
  projectId       String    @db.Uuid
  startTime       DateTime  @db.Timestamptz
  endTime         DateTime  @db.Timestamptz
  calculatedHours Decimal   @db.Decimal(5, 2)
  createdAt       DateTime? @default(now()) @db.Timestamptz

  // Relacje
  employee      Employee       @relation(fields: [employeeId], references: [id])
  payrollExport PayrollExport? @relation(fields: [payrollExportId], references: [id])
  project       Project        @relation(fields: [projectId], references: [id])

  @@index([employeeId])
  @@index([projectId])
  @@index([payrollExportId])
}

/// Zatwierdzone paczki rozliczeniowe. Chronią przed podwojnym wyeksportowaniem tych samych godzin.
model PayrollExport {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  periodMonth       Int
  periodYear        Int
  generatedByUserId String    @db.Uuid
  totalEmployees    Int
  fileUrl           String?
  createdAt         DateTime? @default(now()) @db.Timestamptz

  // Relacje
  generatedBy Employee    @relation("ExportGenerator", fields: [generatedByUserId], references: [id])
  timeEntries TimeEntry[]

  @@index([generatedByUserId])
}

model Reader {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String   @db.Uuid
  serialNumber String   @unique
  locationName String?
  isActive     Boolean? @default(true)

  // Relacje
  project    Project     @relation(fields: [projectId], references: [id])
  timeEvents TimeEvent[]

  @@index([projectId])
}

model Document {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId      String    @db.Uuid
  contractId      String?   @db.Uuid
  certificationId String?   @db.Uuid
  fileName        String
  fileUrl         String
  createdAt       DateTime? @default(now()) @db.Timestamptz

  // Relacje
  certification EmployeeCertification? @relation(fields: [certificationId], references: [id])
  contract      Contract?              @relation(fields: [contractId], references: [id])
  employee      Employee               @relation(fields: [employeeId], references: [id])
  absences      Absence[]

  @@index([employeeId])
  @@index([contractId])
  @@index([certificationId])
}

/// Tabela projektow/budow
model Project {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  internalCode String?       @unique
  address      String?
  status       ProjectStatus @default(ACTIVE)
  startDate    DateTime?     @db.Timestamptz
  endDate      DateTime?     @db.Timestamptz
  createdAt    DateTime?     @default(now()) @db.Timestamptz
  updatedAt    DateTime?     @db.Timestamptz

  // Relacje zwrotne
  assignments EmployeeAssignment[]
  readers     Reader[]
  timeEntries TimeEntry[]
}

/// Ewidencja konkretnych szkoleń przypisanych do pracownikow.
model EmployeeCertification {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId        String    @db.Uuid
  dictionaryId      String    @db.Uuid
  certificateNumber String?
  issuedAt          DateTime  @db.Timestamptz
  expiresAt         DateTime  @db.Timestamptz
  createdAt         DateTime? @default(now()) @db.Timestamptz
  updatedAt         DateTime? @db.Timestamptz

  // Relacje
  dictionary CertificationDictionary @relation(fields: [dictionaryId], references: [id])
  employee   Employee                @relation(fields: [employeeId], references: [id])
  documents  Document[]

  @@index([employeeId])
  @@index([dictionaryId])
}

/// Surowe zdarzenia z czytnikow (Log typu Append-Only. Tego NIE EDYTUJEMY)
model TimeEvent {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String          @db.Uuid
  readerId   String          @db.Uuid
  action     TimeEventAction
  eventTime  DateTime        @db.Timestamptz
  createdAt  DateTime?       @default(now()) @db.Timestamptz

  // Relacje
  employee  Employee  @relation(fields: [employeeId], references: [id])
  reader    Reader    @relation(fields: [readerId], references: [id])
  anomalies Anomaly[]

  @@index([employeeId])
  @@index([readerId])
}

/// Historia umow pracownikow. Pozwala śledzić zmiany stawek w czasie.
model Contract {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String       @db.Uuid
  type         ContractType
  salaryAmount Decimal      @db.Decimal(12, 2)
  startDate    DateTime     @db.Timestamptz
  endDate      DateTime?    @db.Timestamptz
  isCurrent    Boolean      @default(true)
  createdAt    DateTime?    @default(now()) @db.Timestamptz
  updatedAt    DateTime?    @db.Timestamptz

  // Relacje
  employee  Employee   @relation(fields: [employeeId], references: [id])
  documents Document[]

  @@index([employeeId])
}
