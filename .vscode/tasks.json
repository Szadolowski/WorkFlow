{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "docker",
      "type": "shell",
      "command": "docker-compose up -d",
      "icon": { "id": "terminal", "color": "terminal.ansiCyan" },
      "presentation": {
        "panel": "shared",
        "group": "dev",
        "close": true
      }
    },
    {
      "label": "prisma setup",
      "type": "shell",
      "command": "sleep 3 && npx prisma generate && npx prisma db push",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "icon": { "id": "warning", "color": "terminal.ansiYellow" },
      "presentation": { "panel": "shared", "group": "dev" },
      "dependsOn": ["docker"]
    },
    {
      "label": "nest backend",
      "type": "shell",
      "command": "npm run start:dev",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting Nest application...",
          "endsPattern": ".*Nest application successfully started.*"
        },
        "pattern": { "regexp": "^.*" }
      },
      "icon": { "id": "terminal", "color": "terminal.ansiMagenta" },
      "presentation": { "panel": "new", "group": "dev" },
      "dependsOn": ["prisma setup"]
    },
    {
      "label": "next frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*(starting|compiling).*",
          "endsPattern": ".*(Ready|ready) in.*"
        },
        "pattern": { "regexp": "^.*" }
      },
      "icon": { "id": "terminal", "color": "terminal.ansiGreen" },
      "presentation": { "panel": "new", "group": "dev" }
    },
    {
      "label": "Uruchom wszystko",
      "dependsOn": ["docker", "nest backend", "next frontend"],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
